PORT=5000
DATABASE_URL="postgresql://username:password@localhost:5432/aichat"

# Google Gemini API Key (Required)
# Get your free API key from: https://makersuite.google.com/app/apikey
# Steps:
# 1. Go to the link above
# 2. Sign in with your Google account
# 3. Click "Create API Key"
# 4. Copy the key and paste it below
GOOGLE_API_KEY=your_google_api_key_here

# Google Custom Search Engine ID (Optional - for web search feature)
# Get from: https://programmablesearchengine.google.com/
# Steps:
# 1. Create a new search engine
# 2. Select "Search the entire web"
# 3. Copy the Search Engine ID (cx parameter from the embed code)
# 4. Paste it below
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# OpenAI API Key (Legacy - Optional, not used with current WebSocket implementation)
OPENAI_API_KEY=your_openai_key_if_needed
