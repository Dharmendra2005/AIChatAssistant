generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model ChatSession {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  messages  Message[]
}

model Message {
  id        String   @id @default(uuid())
  role      String
  content   String
  createdAt DateTime @default(now())

  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id])
}
